# Smoke Test Credentials
# Copy this file to .env and fill in your credentials

# Embeddings (Maia Router)
EMBEDDINGS_API_KEY=sk-
EMBEDDINGS_ENDPOINT=https://api.maiarouter.ai/v1/embeddings
EMBEDDINGS_MODEL=openai/text-embedding-3-small

# Provider (DeepSeek)
PROVIDER_TYPE=deepseek
PROVIDER_API_KEY=sk-
PROVIDER_MODEL=deepseek-chat

# Optional: use provider-specific variables instead of PROVIDER_API_KEY
# DEEPSEEK_API_KEY=sk-
# ZAI_API_KEY=sk-
